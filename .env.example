# CLI Academy — Environment Variable Reference
# ============================================================
# Copy this file to .env (root) and apps/web/.env for local development.
# NEVER commit .env files with real secrets. All keys listed here must be
# injected via deployment secrets (GitHub Secrets / Vercel env vars / etc.)
# at deploy time.
#
# !! SECURITY WARNING !!
# If you suspect any key was ever committed to git, rotate it immediately
# at the provider's dashboard before doing anything else.
# ============================================================

# ── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — find in Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Anon key — safe to expose to the browser; RLS protects the data
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY, never expose to the browser
# Used by: apps/api/, apps/web/lib/supabase/server.ts (SSR), curriculum sync
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret — used by the FastAPI backend to verify Supabase JWTs
# Find in Supabase dashboard → Settings → API → JWT Settings
SUPABASE_JWT_SECRET=

# ── Anthropic ────────────────────────────────────────────────────────────────
# API key for AI tutor and lesson verification
# Create at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Model to use (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Stripe (optional — app runs free-only without these) ─────────────────────
# Secret key — SERVER ONLY
STRIPE_SECRET_KEY=
# Webhook signing secret (from Stripe dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=
# Price IDs — create in Stripe dashboard → Products
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
# Publishable key — safe for the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Error tracking (optional — app runs without these) ───────────────────────
# Sentry DSN — create project at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Product analytics (optional) ─────────────────────────────────────────────
# PostHog — create project at https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Email (optional — for transactional email) ────────────────────────────────
RESEND_API_KEY=

# ── App behaviour ────────────────────────────────────────────────────────────
# Set to "production" to disable FastAPI /docs and /redoc endpoints
ENV=development
LOG_LEVEL=info
# Comma-separated list of allowed CORS origins for the FastAPI backend
ALLOWED_ORIGINS=http://localhost:3000

# ── Admin ────────────────────────────────────────────────────────────────────
# Email address granted admin bypass in Supabase RLS checks
ADMIN_EMAIL=
